# Copy this file to `.env` and set your API key(s).
# WARNING: Do NOT commit your real API key to source control.

# If you want to call OpenAI directly (requires your own OpenAI key):
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Recommended: Use the ArthaAI backend function instead (no key needed in frontend)
# The default points to the public Supabase function in the shared repository.
VITE_ARTHA_CHAT_URL=https://twukwwvxkzzqzneyyxvu.supabase.co/functions/v1/artha-chat

# Optional: change the OpenAI model when using OpenAI directly
# VITE_OPENAI_MODEL=gpt-3.5-turbo
